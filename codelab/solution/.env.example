# ============================================
# Gemini API Configuration
# ============================================
# Get your key at: https://aistudio.google.com/api-keys
# Billing must be enabled — each run costs ~$0.50–$1.00
GEMINI_API_KEY=your-key-here

# ============================================
# Debug (optional)
# ============================================
# Set to true to log every HTTP call and every streaming event
# DEBUG=true

# ============================================
# Agent Platform (optional bonus section)
# ============================================
# Uncomment and fill in to use the Gemini Enterprise Agent Platform instead of the Gemini API.
# GEMINI_API_KEY above is still required for PDF downloads even in Vertex mode.
# USE_VERTEX=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global
